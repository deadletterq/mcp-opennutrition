{
  "name": "mcp-opennutrition",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "bin": {
    "mcp-opennutrition": "./build/index.js"
  },
  "scripts": {
    "build": "rm -rf build && tsc && npm run convert-data && chmod 755 build/index.js",
    "build:skip-data": "rm -rf build && tsc && chmod 755 build/index.js",
    "inspector": "tsc && npm run convert-data && npx @modelcontextprotocol/inspector npx tsx src/index.ts",
    "convert-data": "tsx scripts/decompress-dataset.ts && tsx scripts/tsv-to-sqlite.ts && rm -rf data_local_temp",
    "docker:build": "docker build -t mcp-opennutrition:latest .",
    "docker:run": "docker run --rm -it -v opennutrition-data:/data -p 3000:3000 mcp-opennutrition:latest",
    "docker:dev": "docker-compose up --build",
    "docker:dev:down": "docker-compose down",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up --build -d",
    "docker:prod:down": "docker-compose -f docker-compose.prod.yml down",
    "docker:logs": "docker-compose logs -f",
    "docker:prod:logs": "docker-compose -f docker-compose.prod.yml logs -f",
    "docker:clean": "docker system prune -f"
  },
  "files": [
    "build"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "MCP implementation for OpenNutrition dataset access. Provides  listing, querying, and filtering foods.",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/yauzl": "^2.10.3",
    "better-sqlite3": "^11.7.0",
    "express": "^4.18.2",
    "papaparse": "^5.4.1",
    "yauzl": "^3.2.0",
    "zod": "^3.25.46"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.29",
    "@types/papaparse": "^5.3.16",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
