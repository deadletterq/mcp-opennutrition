# Environment variables for MCP OpenNutrition

# Application settings
NODE_ENV=production

# Database settings
DB_PATH=/data/opennutrition_foods.db

# Dataset settings
DATASET_URL=https://www.opennutrition.app/static/datasets/opennutrition-dataset-2025.1.zip

# MCP Server settings
MCP_SERVER_NAME=mcp-opennutrition
MCP_SERVER_VERSION=1.0.0

# Logging
LOG_LEVEL=info

# Health check
HEALTH_CHECK_PORT=3000

# Development only (not used in production)
DEBUG=false